{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "PYTHONPATH=${CLAUDE_PLUGIN_ROOT}/scripts python3 -m pes.adapters.hook_adapter session-start"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "PYTHONPATH=${CLAUDE_PLUGIN_ROOT}/scripts python3 -m pes.adapters.hook_adapter pre-tool-use"
          }
        ]
      }
    ]
  }
}
