{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Partner Profile",
  "description": "Schema for SBIR/STTR research institution partner profile validation",
  "type": "object",
  "required": [
    "partner_name",
    "partner_slug",
    "partner_type",
    "capabilities",
    "key_personnel",
    "facilities",
    "past_collaborations",
    "sttr_eligibility",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "partner_name": {
      "type": "string",
      "minLength": 1
    },
    "partner_slug": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$"
    },
    "partner_type": {
      "type": "string",
      "enum": ["university", "federally_funded_rdc", "nonprofit_research"]
    },
    "capabilities": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "key_personnel": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "role", "expertise"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "role": { "type": "string", "minLength": 1 },
          "expertise": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          }
        }
      }
    },
    "facilities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "description": { "type": "string" }
        }
      }
    },
    "past_collaborations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["agency", "topic_area", "outcome"],
        "properties": {
          "agency": { "type": "string" },
          "topic_area": { "type": "string" },
          "outcome": { "type": "string" },
          "year": { "type": "integer" }
        }
      }
    },
    "sttr_eligibility": {
      "type": "object",
      "required": ["qualifies", "minimum_effort_capable"],
      "properties": {
        "qualifies": { "type": "boolean" },
        "minimum_effort_capable": { "type": "boolean" },
        "notes": { "type": "string" }
      }
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "sources": {
      "type": "object",
      "properties": {
        "web_references": {
          "type": "array",
          "description": "URLs consulted during partner research phase",
          "items": {
            "type": "object",
            "required": ["url", "label"],
            "properties": {
              "url": { "type": "string" },
              "label": { "type": "string" },
              "accessed_at": { "type": "string", "format": "date-time" }
            }
          }
        },
        "documents_scanned": {
          "type": "array",
          "description": "Local file paths provided during partner profile creation",
          "items": {
            "type": "object",
            "required": ["path"],
            "properties": {
              "path": { "type": "string" },
              "label": { "type": "string" },
              "scanned_at": { "type": "string", "format": "date-time" }
            }
          }
        }
      }
    }
  }
}
